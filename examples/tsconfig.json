{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"jsx": "preserve",
		"lib": ["ES2022"],
		"types": ["node"],
		"typeRoots": ["./node_modules/@types"]
	},
	"include": ["**/*.ts", "**/*.vue", "vue-shims.d.ts"],
	"exclude": ["node_modules"]
}
