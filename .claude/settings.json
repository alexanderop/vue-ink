{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup|resume",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/inject-brain.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "brain/",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/auto-index-brain.sh"
					}
				]
			}
		],
		"PreCompact": [
			{
				"matcher": "auto",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/extract-brain.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/queue-brain-extract.sh"
					}
				]
			}
		]
	}
}
