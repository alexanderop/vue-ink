{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup|resume",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/inject-brain.sh"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-critical-files.sh"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"if": "Bash(pnpm add *)",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-deps.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "brain/",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/auto-index-brain.sh"
					}
				]
			},
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "jq -r '.tool_response.filePath // .tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && pnpm exec oxfmt \"$f\" 2>/dev/null; } || true"
					}
				]
			}
		],
		"PreCompact": [
			{
				"matcher": "auto",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/extract-brain.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/queue-brain-extract.sh"
					},
					{
						"type": "command",
						"command": "command -v osascript >/dev/null && osascript -e 'display notification \"Turn complete\" with title \"Claude Code\" subtitle \"vue-ink\"' 2>/dev/null || true"
					}
				]
			}
		]
	}
}
