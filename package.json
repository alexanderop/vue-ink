{
	"name": "vue-ink",
	"version": "0.0.1",
	"description": "Vue 3 port of Ink — terminal renderer for Vue components",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsc --noEmit",
		"typecheck": "tsc --noEmit",
		"lint": "node -e \"process.exit(0)\"",
		"test": "npm run typecheck && npm run lint && vitest run"
	},
	"dependencies": {
		"@alcalzone/ansi-tokenize": "^0.3.0",
		"ansi-escapes": "^7.3.0",
		"chalk": "^5.6.2",
		"cli-truncate": "^6.0.0",
		"indent-string": "^5.0.0",
		"slice-ansi": "^9.0.0",
		"string-width": "^8.2.0",
		"vue": "^3.5.13",
		"widest-line": "^6.0.0",
		"wrap-ansi": "^10.0.0",
		"yoga-layout": "~3.2.1"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"@vue/compiler-sfc": "^3.5.13",
		"node-pty": "^1.0.0",
		"strip-ansi": "^7.1.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	}
}
