{
	"name": "@vue-ink/components",
	"version": "0.0.1",
	"description": "First-party Vue components for vue-ink (Box, Text, Newline, Spacer, Transform, Static).",
	"license": "MIT",
	"author": "Alexander Opalic <opalic@gmx.net>",
	"homepage": "https://github.com/alexanderop/vue-ink#readme",
	"bugs": "https://github.com/alexanderop/vue-ink/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alexanderop/vue-ink.git",
		"directory": "packages/components"
	},
	"keywords": [
		"vue",
		"ink",
		"terminal",
		"cli",
		"tui",
		"components",
		"vue-ink"
	],
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsc -p tsconfig.build.json",
		"clean": "rm -rf dist",
		"prepublishOnly": "pnpm run clean && pnpm run build"
	},
	"dependencies": {
		"@vue-ink/core": "workspace:^",
		"chalk": "^5.6.2",
		"cli-boxes": "^4.0.1",
		"type-fest": "^4.41.0"
	},
	"peerDependencies": {
		"vue": "^3.5.0"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"vue": "catalog:"
	},
	"engines": {
		"node": ">=22"
	}
}
