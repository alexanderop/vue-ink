{
	"name": "@vue-ink/renderer",
	"version": "0.0.1",
	"description": "Vue custom renderer for vue-ink — bridges Vue reactivity to the terminal DOM in @vue-ink/core.",
	"license": "MIT",
	"author": "Alexander Opalic <opalic@gmx.net>",
	"homepage": "https://github.com/alexanderop/vue-ink#readme",
	"bugs": "https://github.com/alexanderop/vue-ink/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alexanderop/vue-ink.git",
		"directory": "packages/renderer"
	},
	"keywords": [
		"vue",
		"ink",
		"terminal",
		"cli",
		"tui",
		"renderer",
		"vue-ink"
	],
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsc -p tsconfig.build.json",
		"clean": "rm -rf dist",
		"prepublishOnly": "pnpm run clean && pnpm run build"
	},
	"dependencies": {
		"@vue-ink/core": "workspace:^",
		"ansi-escapes": "^7.3.0",
		"ws": "^8.18.0",
		"yoga-layout": "catalog:"
	},
	"peerDependencies": {
		"@vue/devtools": ">=7.0.0",
		"vue": "^3.5.0"
	},
	"peerDependenciesMeta": {
		"@vue/devtools": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@types/ws": "^8.5.13",
		"@vue/runtime-core": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"vue": "catalog:"
	},
	"engines": {
		"node": ">=22"
	}
}
