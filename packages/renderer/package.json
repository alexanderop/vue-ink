{
  "name": "@vue-ink/renderer",
  "version": "0.0.1",
  "description": "Vue custom renderer for vue-ink — bridges Vue reactivity to the terminal DOM in @vue-ink/core.",
  "keywords": [
    "cli",
    "ink",
    "renderer",
    "terminal",
    "tui",
    "vue",
    "vue-ink"
  ],
  "homepage": "https://github.com/alexanderop/vue-ink#readme",
  "bugs": "https://github.com/alexanderop/vue-ink/issues",
  "license": "MIT",
  "author": "Alexander Opalic <opalic@gmx.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexanderop/vue-ink.git",
    "directory": "packages/renderer"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint:package": "publint --strict && attw --pack . --profile node16",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@vue-ink/core": "workspace:^",
    "@vue/runtime-core": "catalog:",
    "ansi-escapes": "^7.3.0",
    "string-width": "^8.2.0",
    "ws": "^8.18.0",
    "yoga-layout": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/ws": "^8.5.13",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "@vue/devtools": ">=7.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@vue/devtools": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
