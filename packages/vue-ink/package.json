{
  "name": "vueink",
  "version": "0.0.1",
  "description": "Vue 3 port of Ink — build interactive terminal UIs with Vue components.",
  "keywords": [
    "cli",
    "ink",
    "react-ink",
    "terminal",
    "tui",
    "vue",
    "vue-ink",
    "vue3",
    "yoga-layout"
  ],
  "homepage": "https://github.com/alexanderop/vue-ink#readme",
  "bugs": "https://github.com/alexanderop/vue-ink/issues",
  "license": "MIT",
  "author": "Alexander Opalic <opalic@gmx.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexanderop/vue-ink.git",
    "directory": "packages/vue-ink"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./dts-bundle": "./dist/index.bundle.d.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./dts-bundle": "./dist/index.bundle.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && pnpm run build:dts-bundle",
    "build:dts-bundle": "rollup -c rollup.dts.config.mjs",
    "clean": "rm -rf dist",
    "test": "pnpm typecheck && vitest run",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run --config vitest.bench.config.ts",
    "lint:package": "publint --strict && attw --pack . --profile node16 --ignore-rules cjs-resolves-to-esm",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@vue-ink/components": "workspace:^",
    "@vue-ink/renderer": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "^19.2.0",
    "@vitest/coverage-v8": "catalog:",
    "@vue-ink/core": "workspace:^",
    "@vue-ink/testing-library": "workspace:^",
    "@vue/compiler-sfc": "^3.5.13",
    "ansi-escapes": "^7.3.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-boxes": "^4.0.1",
    "fast-check": "^4.8.0",
    "indent-string": "^5.0.0",
    "ink": "^7.0.3",
    "node-pty": "^1.0.0",
    "react": "^19.2.0",
    "slice-ansi": "^7.1.2",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.1.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "yoga-layout": "catalog:"
  },
  "peerDependencies": {
    "@vue/devtools": ">=7.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@vue/devtools": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
