{
	"name": "vue-ink",
	"version": "0.0.1",
	"description": "Vue 3 port of Ink — terminal renderer for Vue components",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsc --noEmit",
		"test": "pnpm typecheck && vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@vue-ink/components": "workspace:*",
		"@vue-ink/renderer": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"@vue-ink/core": "workspace:*",
		"@vue/compiler-sfc": "^3.5.13",
		"chalk": "^5.6.2",
		"node-pty": "^1.0.0",
		"strip-ansi": "^7.1.0",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"vue": "catalog:",
		"yoga-layout": "catalog:"
	},
	"engines": {
		"node": ">=22"
	}
}
