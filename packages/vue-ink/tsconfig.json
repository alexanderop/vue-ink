{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"jsx": "preserve",
		"lib": ["ES2022"],
		"types": ["node"]
	},
	"include": ["src/**/*", "test/**/*", "bin/**/*", "vitest.config.ts"]
}
