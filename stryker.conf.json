{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "packages/vue-ink/vitest.mutation.config.ts",
    "related": false
  },
  "mutate": [
    "packages/core/src/ansi-tokenizer.ts",
    "packages/core/src/colorize.ts",
    "packages/core/src/measure-text.ts",
    "packages/core/src/sanitize-ansi.ts",
    "packages/core/src/squash-text-nodes.ts",
    "packages/core/src/wrap-text.ts"
  ],
  "ignorePatterns": ["coverage", "repos", "apps", "packages/docs", "packages/*/dist"],
  "coverageAnalysis": "perTest",
  "incremental": true,
  "concurrency": "50%",
  "reporters": ["clear-text", "progress", "html", "json"],
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 80
  }
}
